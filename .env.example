# 复制为 .env 并填入真实值; .env 已被 .gitignore 忽略, 不会提交
# 华为云 IoT / MQTT
MQTT_BROKER=your-iot-broker.myhuaweicloud.com
MQTT_PORT=8883
MQTT_DEVICE_ID=YOUR_DEVICE_ID
MQTT_CLIENT_ID=YOUR_CLIENT_ID
MQTT_USERNAME=YOUR_USERNAME
MQTT_PASSWORD=YOUR_PASSWORD

# RTP 视频流服务器
RTP_HOST=YOUR_RTP_SERVER_IP
RTP_PORT=5004

# 串口 (RK3588 默认 /dev/ttyS9)
SERIAL_PORT=/dev/ttyS9
